# ── 数据库 ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=portkey

# ── JWT ──
JWT_SECRET=change-me-to-a-random-string
PORT=3100

# ── 语义摘要（Agent 行为描述 LLM 提炼，可选）──
# 使用 OpenAI 兼容 API，填入你的 Key 以启用；留空则跳过
SUMMARIZE_API_KEY=
SUMMARIZE_API_URL=https://api.deepseek.com/v1
SUMMARIZE_MODEL=deepseek-chat

# ── 阿里云短信（Dysmsapi）──
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=你的签名
ALIYUN_SMS_TEMPLATE_CODE=SMS_XXXXXXXXXXX

# 开发模式设为 true 可跳过短信发送，将验证码打印到控制台
SMS_DEV_MODE=false
