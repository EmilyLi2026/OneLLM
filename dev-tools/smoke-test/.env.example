# OneLLM Provider Smoke Test — 环境变量配置
# 复制此文件为 .env，填入你有 API Key 的厂商
# cp .env.example .env
#
# 每个厂商的 Key 获取地址见下方注释

# ── 国产厂商 P0（7家核心） ──

# DeepSeek 深度求索 → https://platform.deepseek.com/api_keys
ONELLM_DEEPSEEK_KEY=

# 阿里云 通义千问 → https://dashscope.console.aliyun.com/apiKey
ONELLM_DASHSCOPE_KEY=

# 智谱AI GLM → https://open.bigmodel.cn/usercenter/apikeys（glm-4-flash 免费）
ONELLM_ZHIPU_KEY=

# 月之暗面 Kimi → https://platform.moonshot.cn/console/api-keys
ONELLM_MOONSHOT_KEY=

# MiniMax 稀宇 → https://platform.minimaxi.com/user-center/basic-information/interface-key
ONELLM_MINIMAX_KEY=

# 百度智能云 文心 → https://console.bce.baidu.com/iam/#/iam/apikey/list（ernie-speed 免费）
ONELLM_BAIDU_KEY=

# 字节跳动 豆包 → https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ONELLM_BYTEDANCE_KEY=

# ── 国产厂商 P1（5家扩展） ──

# 科大讯飞 星火 → https://console.xfyun.cn/app/myapp
ONELLM_XUNFEI_KEY=

# 百川智能 → https://platform.baichuan-ai.com/console/apikey
ONELLM_BAICHUAN_KEY=

# 腾讯混元 → https://console.cloud.tencent.com/hunyuan/start
ONELLM_TENCENT_KEY=

# 零一万物 Yi → https://platform.lingyiwanwu.com/apikeys
ONELLM_LINGYI_KEY=

# 硅基流动 → https://cloud.siliconflow.cn/account/ak（有免费额度）
ONELLM_SILICONFLOW_KEY=

# ── 国际主流（可选测试） ──

# OpenAI → https://platform.openai.com/api-keys
# ONELLM_OPENAI_KEY=

# Anthropic Claude → https://console.anthropic.com/settings/keys
# ONELLM_ANTHROPIC_KEY=

# Google Gemini → https://aistudio.google.com/app/apikey
# ONELLM_GOOGLE_KEY=

# ── 网关配置 ──

# 网关地址（默认 http://localhost:8787）
# ONELLM_GATEWAY_URL=http://localhost:9799

# 全链路模式：使用 OneLLM 虚拟 Key 测试（走虚拟Key→绑定→Provider完整链路）
# 设置此项后，会使用虚拟 Key 调用网关，不再需要逐一配置上面各厂商的 Key
# ONELLM_GATEWAY_KEY=aihub_sk_your_virtual_key_here

# 单请求超时毫秒（默认 30000）
# ONELLM_SMOKE_TIMEOUT=30000
